{
  "//": "IDE support only. Chronicle's server compiles this plugin (esbuild) — you never run a build.",
  "compilerOptions": {
    "target": "ES2020", "module": "ESNext", "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"], "jsx": "react-jsx", "strict": true,
    "skipLibCheck": true, "noEmit": true, "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
